import os
import sys
from loguru import logger
from datetime import datetime

P_PATH = os.path.dirname(os.path.abspath(__file__))

#########################################
# Local Configs
#########################################

HOME_PATH = os.path.expanduser("~")
LOGGER_PATH = os.path.join(P_PATH, "log", f"PackSpec_{datetime.now().strftime('%Y%m%d')}.log")
# 配置 loguru 日志
logger.remove()
logger.add(sys.stderr, level="INFO")
logger.add(
    LOGGER_PATH,
    level="DEBUG",
    rotation="8 MB",
    format="{time:YYYY-MM-DD HH:mm:ss} | {level} | {message}",
)
PACK_PATH = os.path.join(P_PATH, "packed_files")
SPEC_LOG_PATH = os.path.join(P_PATH, "spec_logs")
SCRIPTS_PATH = os.path.join(P_PATH, "scripts")

